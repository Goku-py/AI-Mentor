# AI Code Mentor - Environment Configuration Template
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────────────
# Google Gemini API Configuration
# ──────────────────────────────────────────────────────
# Get your API key from: https://makersuite.google.com/app/apikey
# Required for AI Mentor feedback feature
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# ──────────────────────────────────────────────────────
# Flask Server Configuration
# ──────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True

# Port the Flask server listens on (Railway/Render set this automatically)
PORT=5000

# ──────────────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for development only.
# In production, set to your frontend URL (e.g. https://your-app.vercel.app)
ALLOWED_ORIGINS=*

# ──────────────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────────────
# In-memory rate limiting (default, resets on restart):
RATE_LIMIT_STORAGE_URI=memory://
# For production with multiple workers, use Redis:
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379

# ──────────────────────────────────────────────────────
# Frontend Configuration (Vite build-time variable)
# ──────────────────────────────────────────────────────
# Set this in Vercel/Netlify environment variables to point
# the frontend to the backend API when deployed separately.
# Leave empty for local development (Vite proxy handles it).
VITE_API_URL=

# ──────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
